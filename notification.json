      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            { "Name": "prefix", "Value": "inbound/" },
            { "Name": "suffix", "Value": "datausa_population.json" }
          ]
        }
      }
    }
  ]
}
